    <!-- GURNEY — moves-->
    <model name="gurney">
    <pose>8.00 -10.00 0 0 0 0</pose><static>false</static>
    <link name="link">
        <inertial><mass>5.0</mass><inertia><ixx>0.1</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.1</iyy><iyz>0</iyz><izz>0.1</izz></inertia></inertial>
        <collision name="collision"><geometry><box><size>2.0 2.0 0.60</size></box></geometry><pose>0 0 0.3 0 0 0</pose></collision>
